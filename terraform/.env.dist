# This is a sample .env file
# Copy it to .env and fill in the values before running Terraform.

# Proxmox API configuration
TF_VAR_pm_api_url=https://your-proxmox-ip:8006/api2/json
TF_VAR_pm_api_token_id=terraform-prov@pve!terraform-token
TF_VAR_pm_api_token_secret=change-me
TF_VAR_pm_tls_insecure=true
